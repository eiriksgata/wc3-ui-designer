{
  "name": "frame-ui-designer",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "tasks": "node -e \"console.log('可用命令：');console.log('  yarn dev         # Vite + MCP Streamable HTTP(8765/mcp) + 运行态桥接(8766)');console.log('  yarn dev:vite    # 仅启动 Vite（不拉起 MCP HTTP）');console.log('  yarn mcp:start   # 仅 MCP HTTP 栈（8765+8766）');console.log('  yarn build       # 构建网页(dist)');console.log('  yarn preview     # 预览构建结果');console.log('  yarn tauri:dev   # Tauri 开发模式(桌面调试)');console.log('  yarn tauri:build # 打包生成 exe');\"",
    "dev": "concurrently -n vite,mcp-http,mcp-bridge -c cyan,green,magenta \"vite\" \"node ./mcp/http-gateway.mjs\" \"node ./mcp/runtime-bridge-http.mjs\"",
    "dev:vite": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "mcp:start": "node ./mcp/start-http-stack.mjs",
    "mcp:start:http": "node ./mcp/http-gateway.mjs",
    "mcp:start:runtime-bridge-http": "node ./mcp/runtime-bridge-http.mjs",
    "mcp:e2e": "node ./mcp/e2e-check.mjs",
    "mcp:streamable-smoke": "node ./mcp/streamable-smoke.mjs",
    "mcp:ci-smoke": "node ./mcp/ci-smoke.mjs",
    "mcp:ci-smoke:strict-runtime": "node ./mcp/ci-smoke.mjs --strict-runtime"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "vue": "^3.5.0",
    "vuetify": "^3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tauri-apps/api": "~2.10.0",
    "@tauri-apps/cli": "~2.10.0",
    "@tauri-apps/plugin-dialog": "~2.7.0",
    "@tauri-apps/plugin-fs": "~2.5.0",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.25"
  }
}
