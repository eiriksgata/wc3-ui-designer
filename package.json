{
  "name": "frame-ui-designer",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "tasks": "node -e \"console.log('可用命令：');console.log('  yarn dev         # 仅 Vite');console.log('  yarn dev:vite    # 同上');console.log('  yarn build       # 构建网页(dist)');console.log('  yarn preview     # 预览构建结果');console.log('  yarn tauri:dev   # Tauri 桌面（内嵌 Rust MCP 8765 + 事件桥接）');console.log('  yarn tauri:build # 打包生成 exe');\"",
    "dev": "vite",
    "dev:vite": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "mcp:e2e": "cargo test -p app --lib --manifest-path src-tauri/Cargo.toml",
    "mcp:streamable-smoke": "node ./scripts/mcp-streamable-smoke.mjs",
    "mcp:ci-smoke": "node ./scripts/mcp-ci-smoke.mjs",
    "mcp:ci-smoke:strict-runtime": "node ./scripts/mcp-ci-smoke.mjs --strict-runtime",
    "mcp:shop-demo": "node ./scripts/mcp-apply-shop-demo.mjs"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "vue": "^3.5.0",
    "vuetify": "^3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tauri-apps/api": "~2.10.0",
    "@tauri-apps/cli": "~2.10.0",
    "@tauri-apps/plugin-dialog": "~2.7.0",
    "@tauri-apps/plugin-fs": "~2.5.0",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.25"
  }
}
